{
  "name": "pints",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --clear-screen=false server/index.ts",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --outdir=dist --format=esm --splitting --external:vite --banner:js=\"import { createRequire } from 'module';const require = createRequire(import.meta.url);\"",
    "start": "NODE_ENV=production node dist/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx seed.ts",
    "fix:coords": "tsx scripts/fixBarCoordinates.ts"
  },
