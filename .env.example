# ============================================
#  DATABASE — required
# ============================================
# Turso (libSQL). Create a free database at turso.tech.
#   turso db create pints-du-soleil
#   turso db show pints-du-soleil --url
#   turso db tokens create pints-du-soleil
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=eyJ...

# ============================================
#  ADMIN — recommended for production
# ============================================
# 6-digit PIN that opens the admin section.
# DEFAULT IS 160127 if unset, which is also what the design docs show — change
# this in production. The PIN is validated server-side; it never enters the
# client bundle.
ADMIN_PIN=160127

# ============================================
#  RUNTIME — set automatically on Fly
# ============================================
PORT=8080
NODE_ENV=production

# ============================================
#  FILE UPLOAD — optional
# ============================================
# Submission-photo uploads need an S3-compatible bucket (Cloudflare R2 works).
# Leave blank to disable photo uploads — admins can still APPROVE submissions
# without photos. The app will not crash if these are missing; the upload
# endpoint will just return a 500.
STORAGE_UPLOAD_URL=
STORAGE_TOKEN=
STORAGE_CDN_URL=
